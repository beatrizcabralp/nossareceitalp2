<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="675.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.nossareceitalp2.EditarReceitaController">
   <children>
      <BorderPane layoutX="10.0" layoutY="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <top>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: FFEF73;" BorderPane.alignment="CENTER">
               <children>
                  <Label styleClass="titulo-nossa-receita" text="Editar Receita" textAlignment="CENTER" wrapText="true">
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
               </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
            </HBox>
         </top>
         <center>
            <ScrollPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
               <content>
                  <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="1000.0" prefWidth="800.0">
                     <children>
                        <VBox alignment="TOP_CENTER" prefHeight="900.0" prefWidth="750.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                           <children>
                              <HBox prefHeight="80.0" prefWidth="700.0" spacing="80.0">
                                 <children>
                                    <VBox prefHeight="200.0" prefWidth="220.0">
                                       <children>
                                          <Label text="Título da Receita" wrapText="true">
                                             <padding>
                                                <Insets bottom="5.0" />
                                             </padding>
                                          </Label>
                                          <TextField fx:id="campoTitulo" prefWidth="100.0" />
                                       </children>
                                    </VBox>
                                    <VBox prefHeight="200.0" prefWidth="220.0">
                                       <children>
                                          <Label text="Carregar foto do perfil" wrapText="true">
                                             <padding>
                                                <Insets bottom="5.0" />
                                             </padding>
                                          </Label>
                                          <Button mnemonicParsing="false" text="Selecionar Arquivo" />
                                       </children>
                                    </VBox>
                                    <VBox prefHeight="200.0" prefWidth="220.0">
                                       <children>
                                          <Label text="Carregar capa da receita" wrapText="true">
                                             <padding>
                                                <Insets bottom="5.0" />
                                             </padding>
                                          </Label>
                                          <Button mnemonicParsing="false" text="Selecionar Arquivo" />
                                       </children>
                                    </VBox>
                                 </children>
                                 <padding>
                                    <Insets left="10.0" top="20.0" />
                                 </padding>
                              </HBox>
                              <HBox alignment="CENTER" prefHeight="100.0" prefWidth="700.0">
                                 <children>
                                    <VBox prefHeight="200.0" prefWidth="780.0">
                                       <children>
                                          <Label text="Ingredientes:">
                                             <font>
                                                <Font name="System Bold" size="14.0" />
                                             </font>
                                             <padding>
                                                <Insets bottom="10.0" left="5.0" />
                                             </padding>
                                          </Label>
                                          <TextArea prefHeight="200.0" prefWidth="200.0" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <HBox alignment="CENTER" prefHeight="100.0" prefWidth="700.0">
                                 <children>
                                    <VBox prefHeight="200.0" prefWidth="780.0">
                                       <children>
                                          <Label text="Modo de preparo:">
                                             <font>
                                                <Font name="System Bold" size="14.0" />
                                             </font>
                                             <padding>
                                                <Insets bottom="10.0" left="5.0" />
                                             </padding>
                                          </Label>
                                          <TextArea prefHeight="200.0" prefWidth="200.0" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <HBox prefHeight="100.0" prefWidth="700.0">
                                 <children>
                                    <VBox prefHeight="200.0" prefWidth="800.0">
                                       <children>
                                          <Label text="Selecione o tipo de comida:">
                                             <font>
                                                <Font name="System Bold" size="14.0" />
                                             </font>
                                             <VBox.margin>
                                                <Insets />
                                             </VBox.margin>
                                             <padding>
                                                <Insets left="10.0" />
                                             </padding>
                                          </Label>
                                          <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
                                             <children>
                                                <RadioButton mnemonicParsing="false" text="Sobremesa">
                                                   <toggleGroup>
                                                      <ToggleGroup fx:id="grupoTipoComida" />
                                                   </toggleGroup>
                                                </RadioButton>
                                                <RadioButton mnemonicParsing="false" text="Salgado" toggleGroup="$grupoTipoComida" />
                                                <RadioButton mnemonicParsing="false" text="Vegano" toggleGroup="$grupoTipoComida" />
                                                <RadioButton mnemonicParsing="false" text="Massas" toggleGroup="$grupoTipoComida" />
                                                <RadioButton mnemonicParsing="false" text="Churrasco" toggleGroup="$grupoTipoComida" />
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="10.0">
                                 <children>
                                    <Button mnemonicParsing="false" onAction="#abrirModalEditarReceita" prefHeight="30.0" prefWidth="100.0" styleClass="botao-editar" stylesheets="@../../../Style/EditarReceita.css" text="Editar Receita" textFill="#19381c" />
                                    <Button mnemonicParsing="false" onAction="#abrirExcluirReceitaAviso" prefHeight="30.0" prefWidth="100.0" styleClass="botao-deletar" stylesheets="@../../../Style/EditarReceita.css" text="Apagar Receita" textFill="#19381c">
                                       <HBox.margin>
                                          <Insets />
                                       </HBox.margin>
                                    </Button>
                                 </children>
                                 <opaqueInsets>
                                    <Insets />
                                 </opaqueInsets>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </AnchorPane>
               </content>
            </ScrollPane>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
